# =============================================================================
# .env.example — YouTube Autopilot SaaS
#
# Copy to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env to git. It's in .gitignore already.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL connection string (from your Supabase project settings)
# Format: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# For local dev: postgresql+asyncpg://postgres:postgres@localhost:5432/youtube_saas
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/youtube_saas

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Get these from your Supabase project: dashboard.supabase.com → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT Secret (must match Supabase JWT secret) ───────────────────────────────
# Get from: Supabase dashboard → Settings → API → JWT Settings → JWT Secret
JWT_SECRET=your-supabase-jwt-secret-here

# ── Encryption ────────────────────────────────────────────────────────────────
# Fernet symmetric key for encrypting stored API keys
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=zq4oF3...

# ── Redis (job queue) ─────────────────────────────────────────────────────────
# Local dev: redis://localhost:6379
# Docker Compose: redis://redis:6379
REDIS_URL=redis://localhost:6379

# ── YouTube OAuth ─────────────────────────────────────────────────────────────
# Create a Google Cloud project → Enable YouTube Data API v3
# Create OAuth 2.0 credentials (Web application type)
# Set Authorized redirect URI to: http://localhost:8000/api/youtube/callback
YOUTUBE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/youtube/callback

# ── Cloudflare R2 (artifact storage) ─────────────────────────────────────────
# Create a bucket at dash.cloudflare.com → R2 Object Storage
# Generate API token with R2 read/write permissions
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=youtube-autopilot
# Set this to your R2 public URL or a Cloudflare CDN domain (optional)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ── CORS (allowed frontend origins) ──────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL of the Streamlit frontend (used for OAuth redirects)
FRONTEND_URL=http://localhost:8501

# URL of the FastAPI backend (used by Streamlit to call the API)
API_URL=http://localhost:8000

# ── Job isolation ─────────────────────────────────────────────────────────────
# Base temp directory for per-job file outputs
JOBS_TMP_DIR=/tmp/jobs

# =============================================================================
# DEVELOPMENT ONLY — single-user mode (bypasses multi-tenant auth)
# Leave empty in production. Only used by the legacy main.py CLI entrypoint.
# =============================================================================
OPENAI_API_KEY=sk-proj-...
